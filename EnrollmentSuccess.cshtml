@page
@model EnrollmentSystemAPI.Pages.Student.EnrollmentSuccessModel
@{
    ViewData["Title"]       = "Enrollment Submitted";
    ViewData["TopbarTitle"] = "Enrollment Form";
    ViewData["StudentName"] = Model.StudentName;
    Layout = "_AppLayout";
}

<div style="max-width:680px;margin:0 auto">

    @* ── Big success banner ───────────────────────────────── *@
    <div class="card" style="text-align:center;padding:48px 36px 40px">

        <div class="success-icon-wrap" style="width:72px;height:72px;font-size:36px;margin-bottom:22px">
            <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>

        <h2 style="font-size:22px;font-weight:700;color:var(--text-primary);margin-bottom:8px">
            Enrollment Submitted Successfully!
        </h2>
        <p style="font-size:14px;color:var(--text-secondary);max-width:440px;margin:0 auto 32px;line-height:1.7">
            Your enrollment form and fee slip have been submitted. The clerk will verify your
            fee payment and approve your enrollment. You'll be notified once it's processed.
        </p>

        @* Detail rows *@
        <div style="max-width:440px;margin:0 auto 32px;text-align:left">
            <div class="upload-result-row">
                <span>Student Name</span>
                <span>@Model.StudentName</span>
            </div>
            <div class="upload-result-row">
                <span>Program</span>
                <span>@Model.Program</span>
            </div>
            <div class="upload-result-row">
                <span>Semester</span>
                <span>@Model.Semester</span>
            </div>
            <div class="upload-result-row">
                <span>Courses Enrolled</span>
                <span>@Model.CourseCount courses / @Model.TotalCredits credit hours</span>
            </div>
            <div class="upload-result-row">
                <span>Fee Slip</span>
                <span>@Model.FeeSlipFileName</span>
            </div>
            <div class="upload-result-row">
                <span>Submission Date</span>
                <span>@Model.SubmissionDate</span>
            </div>
            <div class="upload-result-row">
                <span>Status</span>
                <span class="status-pending-text">● Pending Clerk Verification</span>
            </div>
        </div>

        @* What happens next *@
        <div class="info-box" style="text-align:left;margin-bottom:28px">
            <h4>What happens next?</h4>
            <ul>
                <li>Clerk reviews your fee slip (typically 24–48 hours)</li>
                <li>You'll receive a notification once your fee is verified</li>
                <li>After approval, your enrollment is confirmed for this semester</li>
                <li>You can track progress on the Application Status page</li>
            </ul>
        </div>

        @* Actions *@
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a href="/Student/Dashboard" class="btn btn-secondary" style="width:auto;min-width:150px">
                Back to Dashboard
            </a>
            <a href="/Student/ApplicationStatus" class="btn btn-primary" style="width:auto;min-width:150px">
                Track Status
            </a>
        </div>

    </div>

    @* ── Reference number card ────────────────────────────── *@
    <div class="card" style="display:flex;align-items:center;justify-content:space-between;padding:18px 24px;flex-wrap:wrap;gap:12px">
        <div>
            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:3px">Application Reference</div>
            <div style="font-size:18px;font-weight:700;color:var(--text-primary);letter-spacing:.5px">
                @Model.ReferenceNumber
            </div>
        </div>
        <button onclick="navigator.clipboard.writeText('@Model.ReferenceNumber');Toast.success('Reference number copied!')"
                class="btn btn-outline btn-sm" style="width:auto">
            Copy Reference
        </button>
    </div>

</div>
