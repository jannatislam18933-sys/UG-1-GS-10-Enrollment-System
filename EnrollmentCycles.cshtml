@page
@model EnrollmentSystemAPI.Pages.Admin.EnrollmentCyclesModel
@{
    ViewData["Title"]       = "Enrollment Cycles";
    ViewData["TopbarTitle"] = "Enrollment Cycles";
    ViewData["AdminName"]   = Model.AdminName;
    Layout = "_AdminLayout";
}

<div class="page-header"
     style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div>
        <h1>Enrollment Cycles</h1>
        <p>Manage enrollment periods and academic cycles</p>
    </div>
    <button class="btn btn-primary btn-sm" style="width:auto;margin-top:6px"
            onclick="openCreateModal()">
        + New Cycle
    </button>
</div>

@* ── Active Cycle ─────────────────────────────────────────── *@
@foreach (var c in Model.Cycles.Where(c => c.Status == "Active"))
{
    <div class="cycle-card active-cycle">
        <div class="cycle-header">
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                <span class="cycle-title">@c.Name</span>
                <span class="pill pill-active">Active</span>
                @if (c.EnrollmentOpen)
                {
                    <span class="pill pill-approved" style="font-size:11px">Enrollment Open</span>
                }
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
                <button class="action-btn review" onclick="openEditCycle('@c.Id')">Edit</button>
                <button class="action-btn delete"
                        style="background:#FEE2E2;color:#991B1B"
                        onclick="closeCycle('@c.Id','@c.Name')">
                    Close Cycle
                </button>
            </div>
        </div>
        <div style="font-size:13px;color:var(--text-secondary);margin-bottom:12px">
            @if (c.EnrollmentOpen)
            {
                <span>📅 Enrollment period: <strong>@c.StartDate</strong> — <strong>@c.EndDate</strong></span>
                <span style="margin-left:12px;color:var(--color-warning);font-weight:600">
                    @c.DaysLeft days remaining
                </span>
            }
        </div>
        <div class="cycle-meta">
            <div class="cycle-meta-item">
                <label>Total Enrollments</label>
                <strong>@c.TotalEnrollments</strong>
            </div>
            <div class="cycle-meta-item">
                <label>Start Date</label>
                <strong>@c.StartDate</strong>
            </div>
            <div class="cycle-meta-item">
                <label>End Date</label>
                <strong>@c.EndDate</strong>
            </div>
        </div>
        @if (c.EnrollmentOpen)
        {
            <div style="margin-top:14px;padding:12px 14px;background:rgba(22,163,74,0.08);border-radius:8px;font-size:13px;color:#15803D">
                📢 <strong>Active Enrollment Period</strong> — Students can currently submit their enrollment forms and fee slips.
                Deadline: <strong>@c.EndDate</strong>
            </div>
        }
    </div>
}

@* ── Past Cycles ──────────────────────────────────────────── *@
<div class="card-title" style="margin-top:8px;margin-bottom:12px;font-size:15px;font-weight:700;color:var(--text-primary)">
    Past Cycles
</div>

@foreach (var c in Model.Cycles.Where(c => c.Status != "Active"))
{
    <div class="cycle-card">
        <div class="cycle-header">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <span class="cycle-title">@c.Name</span>
                <span class="pill pill-closed">@c.Status</span>
            </div>
            <button class="action-btn edit" style="font-size:12px"
                    onclick="viewCycleDetails('@c.Id')">View Details</button>
        </div>
        <div class="cycle-meta">
            <div class="cycle-meta-item">
                <label>Total Enrollments</label>
                <strong>@c.TotalEnrollments</strong>
            </div>
            <div class="cycle-meta-item">
                <label>Start Date</label>
                <strong>@c.StartDate</strong>
            </div>
            <div class="cycle-meta-item">
                <label>End Date</label>
                <strong>@c.EndDate</strong>
            </div>
        </div>
    </div>
}

@* ── Create New Cycle section ─────────────────────────────── *@
<div class="card" style="border:2px dashed var(--border-color);background:#FAFBFC;box-shadow:none">
    <div class="card-title">Create New Cycle</div>
    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:18px">
        Set up a new enrollment cycle by defining the start and end dates. Students will be able to
        submit enrollment forms once the cycle is activated.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;flex-wrap:wrap" class="cycle-create-grid">
        <div>
            <div style="font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">
                Define Period
            </div>
            <p style="font-size:12px;color:var(--text-muted)">Set start and end dates for the cycle</p>
        </div>
        <div>
            <div style="font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">
                Configure Rules
            </div>
            <p style="font-size:12px;color:var(--text-muted)">Set enrollment limits and eligibility rules</p>
        </div>
        <div>
            <div style="font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">
                Activate Cycle
            </div>
            <p style="font-size:12px;color:var(--text-muted)">Students can enroll once activated</p>
        </div>
    </div>
    <div style="margin-top:16px">
        <button class="btn btn-primary" style="width:auto;padding:0 28px" onclick="openCreateModal()">
            + Create New Cycle
        </button>
    </div>
</div>

@* ── Create Cycle Modal ───────────────────────────────────── *@
<div class="modal-backdrop" id="createCycleModal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title" id="cycleModalTitle">New Enrollment Cycle</span>
            <button class="modal-close" onclick="closeCreateModal()">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Cycle Name <span style="color:var(--color-danger)">*</span></label>
                <input type="text" id="cy_name" class="form-control"
                       placeholder="e.g. Fall 2026" required />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 16px">
                <div class="form-group">
                    <label class="form-label">Start Date <span style="color:var(--color-danger)">*</span></label>
                    <input type="date" id="cy_start" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">End Date <span style="color:var(--color-danger)">*</span></label>
                    <input type="date" id="cy_end" class="form-control" required />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Max Enrollments</label>
                <input type="number" id="cy_max" class="form-control"
                       placeholder="Leave blank for unlimited" min="1" />
            </div>
            <label class="checkbox-label" style="margin-bottom:8px">
                <input type="checkbox" id="cy_activate" checked />
                Activate immediately after creation
            </label>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeCreateModal()" style="width:auto">Cancel</button>
            <button class="btn btn-primary" onclick="saveCycle()" style="width:auto;min-width:130px"
                    id="saveCycleBtn">Create Cycle</button>
        </div>
    </div>
</div>

@section Scripts {
<style>
@@media(max-width:768px){
  .cycle-create-grid{ grid-template-columns:1fr !important }
}
</style>
<script>
function openCreateModal() {
    document.getElementById('cycleModalTitle').textContent = 'New Enrollment Cycle';
    document.getElementById('cy_name').value = '';
    document.getElementById('cy_start').value = '';
    document.getElementById('cy_end').value = '';
    document.getElementById('createCycleModal').classList.add('open');
}
function closeCreateModal() {
    document.getElementById('createCycleModal').classList.remove('open');
}

async function saveCycle() {
    const name  = document.getElementById('cy_name').value.trim();
    const start = document.getElementById('cy_start').value;
    const end   = document.getElementById('cy_end').value;
    if (!name || !start || !end) { if(window.Toast) Toast.error('Please fill all required fields.'); return; }
    if (new Date(end) <= new Date(start)) { if(window.Toast) Toast.error('End date must be after start date.'); return; }
    const btn = document.getElementById('saveCycleBtn');
    btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>';
    try {
        // await fetch('/api/admin/cycles', { method:'POST', body: JSON.stringify({name,start,end}) });
        await new Promise(r => setTimeout(r, 700));
        closeCreateModal();
        if(window.Toast) Toast.success('Enrollment cycle created successfully.');
    } catch {
        if(window.Toast) Toast.error('Failed to create cycle.');
    } finally {
        btn.disabled = false; btn.innerHTML = 'Create Cycle';
    }
}

function closeCycle(id, name) {
    if (!confirm(`Close the cycle "${name}"? Students will no longer be able to enroll.`)) return;
    // await fetch(`/api/admin/cycles/${id}/close`, { method:'POST' });
    if(window.Toast) Toast.success(`Cycle "${name}" closed.`);
}

function viewCycleDetails(id) {
    if(window.Toast) Toast.info('Cycle details would open here.');
}

function openEditCycle(id) {
    document.getElementById('cycleModalTitle').textContent = 'Edit Cycle';
    document.getElementById('createCycleModal').classList.add('open');
}

document.getElementById('createCycleModal').addEventListener('click', function(e) {
    if (e.target === this) closeCreateModal();
});
</script>
}
