@page
@model EnrollmentSystemAPI.Pages.Student.ProfileModel
@{
    ViewData["Title"]        = "My Profile";
    ViewData["TopbarTitle"]  = "Profile";
    ViewData["StudentName"]  = Model.StudentName;
    Layout = "_AppLayout";
}

<div class="page-header">
  <h1>My Profile</h1>
  <p>View and update your personal information</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
  <div class="alert alert-danger show">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
  <div class="alert alert-success show">@Model.SuccessMessage</div>
}

<form method="post" class="validated-form" novalidate>
  @Html.AntiForgeryToken()

  <div class="card">

    <!-- Personal Information -->
    <div class="form-group">
      <label class="form-label" for="FullName">Full Name</label>
      <input type="text"
             id="FullName"
             name="Input.FullName"
             class="form-control"
             value="@Model.Input.FullName"
             required
             placeholder="Your full name" />
      <span class="field-error">@ModelState["Input.FullName"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="Email">Email Address</label>
      <input type="email"
             id="Email"
             name="Input.Email"
             class="form-control"
             value="@Model.Input.Email"
             required
             placeholder="email@university.edu" />
      <span class="field-error">@ModelState["Input.Email"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="RegistrationNo">Registration Number</label>
      <input type="text"
             id="RegistrationNo"
             class="form-control"
             value="@Model.Input.RegistrationNo"
             readonly
             placeholder="FA21-BSE-042" />
      <p style="font-size:12px;color:var(--text-muted);margin-top:4px">Registration number cannot be changed.</p>
    </div>

    <div class="form-group">
      <label class="form-label" for="Program">Program</label>
      <input type="text"
             id="Program"
             class="form-control"
             value="@Model.Input.Program"
             readonly
             placeholder="BS Computer Science" />
    </div>

    <div class="form-group">
      <label class="form-label" for="CNIC">CNIC</label>
      <input type="text"
             id="CNIC"
             name="Input.CNIC"
             class="form-control"
             value="@Model.Input.CNIC"
             placeholder="12345-1234567-1"
             data-pattern="^\d{5}-\d{7}-\d{1}$"
             data-pattern-msg="CNIC format must be: 12345-1234567-1" />
      <span class="field-error">@ModelState["Input.CNIC"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="PhoneNumber">Phone Number</label>
      <input type="tel"
             id="PhoneNumber"
             name="Input.PhoneNumber"
             class="form-control"
             value="@Model.Input.PhoneNumber"
             placeholder="+92 300 1234567"
             data-pattern="^(\+92|0)[0-9]{10}$"
             data-pattern-msg="Enter a valid Pakistani phone number." />
      <span class="field-error">@ModelState["Input.PhoneNumber"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

  </div>

  <!-- Change Password -->
  <div class="card">
    <div class="card-title">Change Password</div>
    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:20px">
      Leave these fields empty if you don't want to change your password.
    </p>

    <div class="form-group">
      <label class="form-label" for="CurrentPassword">Current Password</label>
      <div class="input-wrapper">
        <input type="password"
               id="CurrentPassword"
               name="Input.CurrentPassword"
               class="form-control"
               placeholder="Enter current password"
               autocomplete="current-password" />
        <button type="button" class="pw-toggle" aria-label="Show password">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="NewPassword">New Password</label>
      <div class="input-wrapper">
        <input type="password"
               id="NewPassword"
               name="Input.NewPassword"
               class="form-control"
               placeholder="Enter new password"
               data-min-length="6"
               autocomplete="new-password" />
        <button type="button" class="pw-toggle" aria-label="Show password">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
      </div>
      <span class="field-error"></span>
    </div>

    <div class="form-group">
      <label class="form-label" for="ConfirmPassword">Confirm New Password</label>
      <div class="input-wrapper">
        <input type="password"
               id="ConfirmPassword"
               name="Input.ConfirmPassword"
               class="form-control"
               placeholder="Confirm new password"
               data-match="#NewPassword"
               autocomplete="new-password" />
        <button type="button" class="pw-toggle" aria-label="Show password">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
      </div>
      <span class="field-error"></span>
    </div>
  </div>

  <!-- Actions -->
  <div class="form-actions">
    <a href="/Student/Dashboard" class="btn btn-secondary" style="width:auto;padding:0 28px">
      Cancel
    </a>
    <button type="submit" class="btn btn-primary" style="width:auto;padding:0 32px">
      Save Changes
    </button>
  </div>

</form>
