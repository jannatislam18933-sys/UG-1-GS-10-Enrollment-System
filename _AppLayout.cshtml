<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] — UAF Enrollment System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- Mobile Sidebar Overlay -->
<div class="sidebar-overlay"></div>

<div class="app-shell">

  <!-- ── Sidebar ──────────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div class="sidebar-logo-text">
        <h3>University</h3>
        <span>Student Portal</span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a href="/Student/Dashboard" class="nav-item" data-page="dashboard">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
        Dashboard
      </a>
      <a href="/Student/UploadFeeSlip" class="nav-item" data-page="upload">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        Upload Fee Slip
      </a>
      <a href="/Student/EnrollmentForm" class="nav-item" data-page="enrollment">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Enrollment Form
      </a>
      <a href="/Student/ApplicationStatus" class="nav-item" data-page="status">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        Application Status
      </a>
      <a href="/Student/Profile" class="nav-item" data-page="profile">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        Profile
      </a>
    </nav>

    <div class="sidebar-footer">
      <form method="post" action="/Account/Logout">
        @Html.AntiForgeryToken()
        <button type="submit" class="logout-btn">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- ── Main Content ──────────────────────────────────────── -->
  <div class="main-content">

    <!-- Top Bar -->
    <header class="topbar">
      <div style="display:flex;align-items:center;gap:14px">
        <button class="hamburger" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <div class="topbar-left">
          <h2>@ViewData["TopbarTitle"]</h2>
          <p>Welcome back, @ViewData["StudentName"]</p>
        </div>
      </div>

      <div class="topbar-right">
        <button class="notif-btn" aria-label="Notifications">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 01-3.46 0"/>
          </svg>
          <span class="notif-dot"></span>
        </button>

        <button class="user-chip">
          @{ var _displayName = ViewData["StudentName"] as string ?? "A"; }
          <div class="user-avatar">@_displayName[0]</div>
          <span>@_displayName</span>
        </button>
      </div>
    </header>

    <!-- Page Body -->
    <main class="page-content">
      @RenderBody()
    </main>

  </div><!-- /main-content -->
</div><!-- /app-shell -->

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
