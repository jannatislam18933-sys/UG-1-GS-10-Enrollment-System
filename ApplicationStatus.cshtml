@page
@model EnrollmentSystemAPI.Pages.Student.ApplicationStatusModel
@{
    ViewData["Title"]        = "Application Status";
    ViewData["TopbarTitle"]  = "Application Status";
    ViewData["StudentName"]  = Model.StudentName;
    Layout = "_AppLayout";
}

<div class="page-header">
  <h1>Application Status</h1>
  <p>Track your enrollment application progress</p>
</div>

<!-- Status Banner -->
<div class="status-banner warning">
  <div class="status-banner-icon">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
  </div>
  <div class="status-banner-body">
    <h3>Fee Verification In Progress</h3>
    <p>Your fee slip is currently being verified by the clerk. This typically takes 24–48 hours.</p>
    <span class="status-badge badge-review" style="display:inline-block;margin-top:8px">In Review</span>
  </div>
</div>

<!-- Application Timeline -->
<div class="card">
  <div class="card-title">Application Timeline</div>

  <div class="timeline">

    <!-- Step 1: Fee Slip Uploaded -->
    <div class="timeline-item" style="position:relative">
      <div class="timeline-connector done" style="position:absolute;left:17px;top:50px;width:2px;height:60px;background:var(--color-success)"></div>
      <div class="timeline-icon done">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div class="timeline-body">
        <h4>Fee Slip Uploaded</h4>
        <p>April 8, 2026 – 10:30 AM</p>
      </div>
      <span class="status-badge badge-completed">Completed</span>
    </div>

    <!-- Step 2: Fee Verification -->
    <div class="timeline-item" style="position:relative">
      <div class="timeline-connector" style="position:absolute;left:17px;top:50px;width:2px;height:60px;background:#E5E7EB"></div>
      <div class="timeline-icon in-prog">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
        </svg>
      </div>
      <div class="timeline-body">
        <h4>Fee Verification</h4>
        <p>Under review by clerk</p>
      </div>
      <span class="status-badge badge-in-progress">In Progress</span>
    </div>

    <!-- Step 3: Enrollment Form -->
    <div class="timeline-item" style="position:relative">
      <div class="timeline-connector" style="position:absolute;left:17px;top:50px;width:2px;height:60px;background:#E5E7EB"></div>
      <div class="timeline-icon waiting">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div class="timeline-body">
        <h4>Enrollment Form Submission</h4>
        <p>Waiting for fee verification</p>
      </div>
      <span class="status-badge badge-pending">Pending</span>
    </div>

    <!-- Step 4: Final Approval -->
    <div class="timeline-item">
      <div class="timeline-icon waiting">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div class="timeline-body">
        <h4>Final Approval</h4>
        <p>Pending</p>
      </div>
      <span class="status-badge badge-pending">Pending</span>
    </div>

  </div>
</div>

<!-- Application Details -->
<div class="card">
  <div class="card-title">Application Details</div>
  <div class="details-grid">
    <div class="detail-item">
      <label>Application ID</label>
      <strong>ENR-2026-042</strong>
    </div>
    <div class="detail-item">
      <label>Submission Date</label>
      <strong>April 8, 2026</strong>
    </div>
    <div class="detail-item">
      <label>Enrollment Cycle</label>
      <strong>Spring 2026</strong>
    </div>
    <div class="detail-item">
      <label>Current Status</label>
      <strong style="color:var(--color-warning)">Fee Verification</strong>
    </div>
  </div>
</div>
