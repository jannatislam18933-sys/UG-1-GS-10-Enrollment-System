@page
@model EnrollmentSystemAPI.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="auth-card">

  <div class="auth-logo">
    <div class="auth-logo-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
      </svg>
    </div>
    <div class="auth-logo-text">
      <h2>University Portal</h2>
      <p>Enrollment System</p>
    </div>
  </div>

  <div class="auth-heading">
    <h1>Forgot Password</h1>
    <p>Reset your student account password</p>
  </div>

  <div class="auth-info-box">
    Enter your registered email address and we'll send you instructions to reset your password.
  </div>

  @if (!string.IsNullOrEmpty(Model.ErrorMessage))
  {
    <div class="alert alert-danger show">@Model.ErrorMessage</div>
  }

  <form method="post" class="validated-form" novalidate>
    @Html.AntiForgeryToken()

    <div class="form-group">
      <label class="form-label" for="Email">Email Address</label>
      <input type="email"
             id="Email"
             name="Email"
             class="form-control"
             placeholder="student@university.edu"
             value="@Model.Email"
             required
             autocomplete="email" />
      <span class="field-error">@ModelState["Email"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">
      Send Reset Link
    </button>

    <a href="/Account/Login" class="back-link">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Login
    </a>
  </form>

</div>
