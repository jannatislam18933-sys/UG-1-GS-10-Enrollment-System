@page
@model EnrollmentSystemAPI.Pages.Student.DashboardModel
@{
    ViewData["Title"]        = "Dashboard";
    ViewData["TopbarTitle"]  = "Dashboard";
    ViewData["StudentName"]  = Model.StudentName;
    Layout = "_AppLayout";
}

<!-- Status Cards -->
<div class="page-header">
  <h1>Dashboard</h1>
  <p>Welcome back, @Model.StudentName</p>
</div>

<div class="status-grid">

  <!-- Spring 2026 -->
  <div class="status-card">
    <span class="status-badge badge-open">Open</span>
    <div class="status-card-icon blue">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
    </div>
    <h3>Spring 2026</h3>
    <p>Current Enrollment Cycle</p>
  </div>

  <!-- Fee Verification -->
  <div class="status-card">
    <span class="status-badge badge-pending">Pending</span>
    <div class="status-card-icon orange">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
    </div>
    <h3>Fee Verification</h3>
    <p>Upload your fee slip</p>
  </div>

  <!-- Enrollment Form -->
  <div class="status-card">
    <span class="status-badge badge-not-started">Not Started</span>
    <div class="status-card-icon red">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
    </div>
    <h3>Enrollment Form</h3>
    <p>Complete after fee verification</p>
  </div>

</div>

<!-- Quick Actions -->
<div class="card">
  <div class="card-title">Quick Actions</div>

  <div class="quick-action-item">
    <div class="quick-action-left">
      <div class="quick-action-icon blue" style="background:#EFF6FF;color:#2563EB">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
      </div>
      <div>
        <h4>Upload Fee Slip</h4>
        <p>Submit your paid challan for verification</p>
      </div>
    </div>
    <a href="/Student/UploadFeeSlip" class="btn btn-primary btn-sm">Upload Now</a>
  </div>

  <div class="quick-action-item">
    <div class="quick-action-left">
      <div class="quick-action-icon" style="background:#F3F4F6;color:#9CA3AF">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
        </svg>
      </div>
      <div>
        <h4>Submit Enrollment Form</h4>
        <p>Available after fee verification</p>
      </div>
    </div>
    <button class="btn btn-sm badge-locked" disabled
            style="background:#F3F4F6;color:#6B7280;border:none;height:34px;padding:0 16px;border-radius:6px;font-size:13px;font-weight:600;cursor:not-allowed">
      🔒 Locked
    </button>
  </div>
</div>

<!-- Important Information -->
<div class="info-box">
  <h4>Important Information</h4>
  <ul>
    <li>Enrollment deadline: April 30, 2026</li>
    <li>Fee verification typically takes 24–48 hours</li>
    <li>You cannot submit enrollment form without verified fee slip</li>
  </ul>
</div>
