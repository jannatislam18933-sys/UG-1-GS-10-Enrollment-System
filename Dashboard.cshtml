@page
@model EnrollmentSystemAPI.Pages.Admin.AdminDashboardModel
@{
    ViewData["Title"]       = "Dashboard";
    ViewData["TopbarTitle"] = "Dashboard";
    ViewData["AdminName"]   = Model.AdminName;
    Layout = "_AdminLayout";
}

<div class="page-header"
     style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div>
        <h1>Dashboard</h1>
        <p>Welcome back, @Model.AdminName — system overview for Spring 2026</p>
    </div>
    <button class="btn btn-outline btn-sm" style="width:auto;margin-top:6px"
            onclick="location.reload()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
        </svg>
        Refresh
    </button>
</div>

@* ── Stat Cards ───────────────────────────────────────────── *@
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">1,230</div>
            <div class="stat-label">Total Enrollments</div>
            <div class="stat-delta up">↑ 12% vs last cycle</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">1,050</div>
            <div class="stat-label">Approved</div>
            <div class="stat-delta up">85% approval rate</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">142</div>
            <div class="stat-label">Pending Review</div>
            <div class="stat-delta neutral">Awaiting clerk action</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9"  y1="9" x2="15" y2="15"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">38</div>
            <div class="stat-label">Rejected</div>
            <div class="stat-delta down">↓ 3% vs last cycle</div>
        </div>
    </div>
</div>

@* ── Charts row ───────────────────────────────────────────── *@
<div class="dash-grid">
    <div class="card">
        <div class="card-title">Enrollment Trend</div>
        <div class="chart-wrap" style="height:210px">
            <canvas id="trendChart"></canvas>
        </div>
    </div>
    <div class="card">
        <div class="card-title">Program Distribution</div>
        <div style="display:flex;align-items:center;gap:24px;height:210px">
            <div style="position:relative;flex-shrink:0;width:170px;height:170px">
                <canvas id="donutChart"></canvas>
            </div>
            <div class="donut-legend">
                <div class="donut-legend-item">
                    <div class="donut-legend-dot" style="background:#2563EB"></div>
                    <span>BS CS / SE&nbsp;<strong>42%</strong></span>
                </div>
                <div class="donut-legend-item">
                    <div class="donut-legend-dot" style="background:#16A34A"></div>
                    <span>BS Other&nbsp;<strong>28%</strong></span>
                </div>
                <div class="donut-legend-item">
                    <div class="donut-legend-dot" style="background:#D97706"></div>
                    <span>MS / MPhil&nbsp;<strong>20%</strong></span>
                </div>
                <div class="donut-legend-item">
                    <div class="donut-legend-dot" style="background:#A855F7"></div>
                    <span>PhD&nbsp;<strong>10%</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Bottom info row ──────────────────────────────────────── *@
<div class="dash-grid-3">
    <div class="card">
        <div class="card-title">Active Enrollment Cycle</div>
        <div style="margin-bottom:8px">
            <div style="font-size:16px;font-weight:700;color:var(--text-primary);margin-bottom:6px">
                Spring 2026
                <span class="pill pill-active" style="font-size:11px;margin-left:6px">Active</span>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px">
            <div>
                <div style="font-size:11px;color:var(--text-secondary)">Start Date</div>
                <div style="font-size:13px;font-weight:600">Jan 15, 2026</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--text-secondary)">End Date</div>
                <div style="font-size:13px;font-weight:600">Apr 30, 2026</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--text-secondary)">Total Enrolled</div>
                <div style="font-size:20px;font-weight:700;color:var(--color-primary)">1,104</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--text-secondary)">Days Left</div>
                <div style="font-size:20px;font-weight:700;color:var(--color-warning)">11</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-title">User Statistics</div>
        <div style="display:flex;flex-direction:column;gap:10px">
            @foreach (var (label, value, color) in new[]{
                ("Total Students",  "1,230", "#2563EB"),
                ("Active Clerks",   "12",    "#16A34A"),
                ("Administrators",  "3",     "#7C3AED")
            })
            {
                <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#F9FAFB;border-radius:8px">
                    <span style="font-size:13px;color:var(--text-secondary)">@label</span>
                    <span style="font-size:18px;font-weight:700;color:@color">@value</span>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-title">System Health</div>
        <div style="display:flex;flex-direction:column;gap:10px">
            @foreach (var (label, value, ok) in new[]{
                ("Database",    "Healthy",        true),
                ("API Status",  "Online",         true),
                ("Last Backup", "2 hours ago",    true)
            })
            {
                <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#F9FAFB;border-radius:8px">
                    <span style="font-size:13px;color:var(--text-secondary)">@label</span>
                    <span class="pill @(ok ? "pill-approved" : "pill-rejected")"
                          style="font-size:11px">@value</span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
// Enrollment trend line chart
new Chart(document.getElementById('trendChart'), {
  type: 'line',
  data: {
    labels: ['Oct','Nov','Dec','Jan','Feb','Mar','Apr'],
    datasets: [{
      label: 'Enrollments',
      data: [400, 520, 480, 750, 900, 1050, 1230],
      borderColor: '#2563EB', backgroundColor: 'rgba(37,99,235,0.08)',
      borderWidth: 2.5, pointRadius: 4, pointBackgroundColor: '#2563EB',
      tension: 0.4, fill: true
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { display: false }, ticks: { font: { size: 11 } } },
      y: { beginAtZero: true, grid: { color: '#F3F4F6' }, ticks: { font: { size: 11 } } }
    }
  }
});

// Program donut chart
new Chart(document.getElementById('donutChart'), {
  type: 'doughnut',
  data: {
    labels: ['BS CS/SE', 'BS Other', 'MS/MPhil', 'PhD'],
    datasets: [{
      data: [42, 28, 20, 10],
      backgroundColor: ['#2563EB', '#16A34A', '#D97706', '#A855F7'],
      borderWidth: 2, borderColor: '#fff', hoverOffset: 6
    }]
  },
  options: {
    responsive: false, cutout: '68%',
    plugins: { legend: { display: false } }
  }
});
</script>
}
