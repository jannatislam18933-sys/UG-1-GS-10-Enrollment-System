@page
@model EnrollmentSystemAPI.Pages.Student.EnrollmentFormModel
@{
    ViewData["Title"]       = "Enrollment Form";
    ViewData["TopbarTitle"] = "Enrollment Form";
    ViewData["StudentName"] = Model.StudentName;
    Layout = "_AppLayout";
}

<div class="page-header">
    <h1>Enrollment Form</h1>
    <p>Fill your enrollment details, select courses and attach your paid fee slip — all submitted together.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger show">@Model.ErrorMessage</div>
}

@* Step indicator *@
<div class="step-bar">
    <div class="step-item active" id="si1">
        <div class="step-circle">1</div>
        <span>Student Info</span>
    </div>
    <div class="step-line"></div>
    <div class="step-item" id="si2">
        <div class="step-circle">2</div>
        <span>Courses</span>
    </div>
    <div class="step-line"></div>
    <div class="step-item" id="si3">
        <div class="step-circle">3</div>
        <span>Fee Slip</span>
    </div>
    <div class="step-line"></div>
    <div class="step-item" id="si4">
        <div class="step-circle">4</div>
        <span>Review</span>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="validated-form" id="enrollForm" novalidate>
    @Html.AntiForgeryToken()

    @* ═══════════════════════════════════════
       SECTION 1 — STUDENT INFORMATION
       ═══════════════════════════════════════ *@
    <div class="enroll-section" id="sec1">
        <div class="card">
            <div class="card-title">
                <span class="sec-num">1</span> Student Information
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label" for="FullName">Full Name <span class="req">*</span></label>
                    <input type="text" id="FullName" name="Input.FullName"
                           class="form-control" value="@Model.Input.FullName"
                           placeholder="Enter your full name" required />
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="FatherName">Father's Name <span class="req">*</span></label>
                    <input type="text" id="FatherName" name="Input.FatherName"
                           class="form-control" value="@Model.Input.FatherName"
                           placeholder="Enter father's name" required />
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="RegistrationNo">Registration No</label>
                    <input type="text" id="RegistrationNo" class="form-control"
                           value="@Model.Input.RegistrationNo" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label" for="CNIC">CNIC <span class="req">*</span></label>
                    <input type="text" id="CNIC" name="Input.CNIC"
                           class="form-control" value="@Model.Input.CNIC"
                           placeholder="12345-1234567-1" required
                           data-pattern="^\d{5}-\d{7}-\d{1}$"
                           data-pattern-msg="Format: 12345-1234567-1" />
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="PhoneNumber">Phone Number <span class="req">*</span></label>
                    <input type="tel" id="PhoneNumber" name="Input.PhoneNumber"
                           class="form-control" value="@Model.Input.PhoneNumber"
                           placeholder="+92 300 0000000" required
                           data-pattern="^(\+92|0)[0-9]{10}$"
                           data-pattern-msg="Enter a valid Pakistani phone number" />
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="Email">Email Address <span class="req">*</span></label>
                    <input type="email" id="Email" name="Input.Email"
                           class="form-control" value="@Model.Input.Email"
                           placeholder="you@university.edu" required />
                    <span class="field-error"></span>
                </div>
                <div class="form-group" style="grid-column:1/-1">
                    <label class="form-label" for="Address">Permanent Address <span class="req">*</span></label>
                    <textarea id="Address" name="Input.Address"
                              class="form-control" rows="2"
                              placeholder="Street, City, Province" required>@Model.Input.Address</textarea>
                    <span class="field-error"></span>
                </div>
            </div>

            <div class="form-grid-3" style="margin-top:4px">
                <div class="form-group">
                    <label class="form-label" for="DegreeProgram">Degree Program <span class="req">*</span></label>
                    <select id="DegreeProgram" name="Input.DegreeProgram" class="form-control" required>
                        <option value="">Select program</option>
                        @foreach (var prog in Model.Programs)
                        {
                            if (Model.Input.DegreeProgram == prog)
                            {
                                <option value="@prog" selected="selected">@prog</option>
                            }
                            else
                            {
                                <option value="@prog">@prog</option>
                            }
                        }
                    </select>
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="Section">Section <span class="req">*</span></label>
                    <select id="Section" name="Input.Section" class="form-control" required>
                        <option value="">Select section</option>
                        @foreach (var sec in new[]{"A","B","C","D","E"})
                        {
                            if (Model.Input.Section == sec)
                            { <option value="@sec" selected="selected">@sec</option> }
                            else
                            { <option value="@sec">@sec</option> }
                        }
                    </select>
                    <span class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="Semester">Semester <span class="req">*</span></label>
                    <select id="Semester" name="Input.Semester" class="form-control" required>
                        <option value="">Select semester</option>
                        @foreach (var s in new[]{"1st","2nd","3rd","4th","5th","6th","7th","8th"})
                        {
                            if (Model.Input.Semester == s)
                            { <option value="@s" selected="selected">@s</option> }
                            else
                            { <option value="@s">@s</option> }
                        }
                    </select>
                    <span class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════
       SECTION 2 — COURSE SELECTION
       ═══════════════════════════════════════ *@
    <div class="enroll-section" id="sec2">
        <div class="card">
            <div class="card-title">
                <span class="sec-num">2</span> Course Selection
                <span style="font-size:12px;font-weight:400;color:var(--text-secondary);margin-left:8px">
                    Mandatory courses are pre-selected
                </span>
            </div>

            @foreach (var course in Model.Courses)
            {
                <div class="course-item @(course.IsMandatory ? "mandatory selected" : "")"
                     data-credits="@course.Credits">
                    <input type="checkbox"
                           name="Input.SelectedCourses"
                           value="@course.Code"
                           id="c_@course.Code"
                           @(course.IsMandatory ? "checked=\"checked\" disabled=\"disabled\"" : "") />
                    <label for="c_@course.Code" class="course-info">
                        <h4>@course.Code — @course.Name</h4>
                        <p>@course.Credits Credit Hours@(course.IsMandatory ? " • Mandatory" : " • Elective")</p>
                    </label>
                    @if (course.IsMandatory)
                    {
                        <span class="course-badge">Required</span>
                    }
                </div>
            }

            @* Supervisor — MS students only *@
            <div id="supervisorSection" style="display:none;margin-top:20px;padding-top:18px;border-top:1px solid var(--border-color)">
                <div class="card-title" style="margin-bottom:12px">
                    <span class="sec-num" style="background:#8B5CF6">S</span> Supervisor
                    <span style="font-size:12px;font-weight:400;color:var(--text-secondary);margin-left:8px">MS / MPhil students only</span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="SupervisorId">Select Supervisor</label>
                    <select id="SupervisorId" name="Input.SupervisorId" class="form-control">
                        <option value="">Choose your supervisor</option>
                        @foreach (var sv in Model.Supervisors)
                        {
                            if (Model.Input.SupervisorId == sv.Id)
                            { <option value="@sv.Id" selected="selected">@sv.Name — @sv.Department</option> }
                            else
                            { <option value="@sv.Id">@sv.Name — @sv.Department</option> }
                        }
                    </select>
                    <span class="field-error"></span>
                </div>
            </div>

            @* Course summary *@
            <div class="enrollment-summary" style="margin-top:20px;padding-top:18px;border-top:1px solid var(--border-color)">
                <div class="sum-item">
                    <label>Total Courses</label>
                    <strong id="totalCourses">0</strong>
                </div>
                <div class="sum-item">
                    <label>Credit Hours</label>
                    <strong id="totalCredits">0</strong>
                </div>
                <div class="sum-item">
                    <label>Semester</label>
                    <strong id="semDisplay">—</strong>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════
       SECTION 3 — FEE SLIP UPLOAD
       ═══════════════════════════════════════ *@
    <div class="enroll-section" id="sec3">
        <div class="card">
            <div class="card-title">
                <span class="sec-num" style="background:#D97706">3</span> Fee Slip
                <span style="font-size:12px;font-weight:400;color:var(--text-secondary);margin-left:8px">
                    Attach your paid challan — verified by clerk after submission
                </span>
            </div>

            <div class="fee-context-box">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" style="flex-shrink:0;margin-top:1px">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r=".5" fill="#D97706"/>
                </svg>
                <p>Your fee slip and enrollment form are submitted <strong>together</strong>. The clerk will verify your fee slip and approve your enrollment in one step.</p>
            </div>

            @* Drop zone *@
            <div class="fee-slip-drop" id="feeSlipDrop">
                <div class="upload-icon" style="width:46px;height:46px;font-size:22px">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                        <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
                    </svg>
                </div>
                <h4>Drop your fee slip here, or click to browse</h4>
                <p>Supports PDF, JPG, PNG — max 5MB</p>
                <button type="button" class="btn btn-outline btn-sm"
                        onclick="document.getElementById('FeeSlipFile').click()">
                    Select File
                </button>
                <input type="file" id="FeeSlipFile" name="Input.FeeSlipFile"
                       accept=".pdf,.jpg,.jpeg,.png" />
            </div>

            @* Preview container *@
            <div id="feeSlipPreview" style="display:none;margin-top:14px"></div>

            @* Transaction ID *@
            <div class="form-group" style="margin-top:18px">
                <label class="form-label" for="TransactionId">Transaction ID
                    <span style="font-weight:400;color:var(--text-muted)">(optional)</span>
                </label>
                <input type="text" id="TransactionId" name="Input.TransactionId"
                       class="form-control"
                       placeholder="Enter transaction ID from your bank challan"
                       value="@Model.Input.TransactionId"
                       data-pattern="^[A-Za-z0-9\-]{0,40}$"
                       data-pattern-msg="Only letters, numbers and hyphens" />
                <p style="font-size:12px;color:var(--text-muted);margin-top:4px">
                    Providing this helps the clerk verify your payment faster.
                </p>
                <span class="field-error"></span>
            </div>

            <div class="upload-instructions" style="margin-top:4px">
                <h4>Fee Slip Requirements</h4>
                <ul>
                    <li>Challan must be clearly visible and readable</li>
                    <li>Amount and payment date must be shown</li>
                    <li>Bank stamp must be visible (if applicable)</li>
                    <li>File must not be blurry, cropped or rotated</li>
                </ul>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════
       SECTION 4 — REVIEW & SUBMIT
       ═══════════════════════════════════════ *@
    <div class="enroll-section" id="sec4">
        <div class="card">
            <div class="card-title">
                <span class="sec-num" style="background:#16A34A">4</span> Review & Submit
            </div>

            <div class="review-grid">
                <div class="review-block">
                    <div class="review-block-title">Student Details</div>
                    <div class="review-row"><span>Name</span><strong id="rv_name">—</strong></div>
                    <div class="review-row"><span>Father's Name</span><strong id="rv_father">—</strong></div>
                    <div class="review-row"><span>Registration No</span><strong>@Model.Input.RegistrationNo</strong></div>
                    <div class="review-row"><span>Program</span><strong id="rv_prog">—</strong></div>
                    <div class="review-row"><span>Section</span><strong id="rv_sec">—</strong></div>
                    <div class="review-row"><span>Semester</span><strong id="rv_sem">—</strong></div>
                    <div class="review-row"><span>Phone</span><strong id="rv_phone">—</strong></div>
                </div>
                <div class="review-block">
                    <div class="review-block-title">Enrollment Summary</div>
                    <div class="review-row"><span>Total Courses</span><strong id="rv_courses">—</strong></div>
                    <div class="review-row"><span>Credit Hours</span><strong id="rv_credits">—</strong></div>
                    <div class="review-row"><span>Fee Slip</span><strong id="rv_feeslip" style="color:var(--color-warning)">Not attached</strong></div>
                    <div class="review-row"><span>Transaction ID</span><strong id="rv_txn">—</strong></div>
                </div>
            </div>

            <div class="declaration-box">
                <label class="checkbox-label" style="align-items:flex-start;gap:10px">
                    <input type="checkbox" id="declaration" name="Input.Declaration" required style="margin-top:2px" />
                    <span style="font-size:13px;color:var(--text-secondary);line-height:1.6">
                        I declare that all information provided is accurate and complete. I understand that
                        submitting false information may result in cancellation of my enrollment.
                    </span>
                </label>
                <span class="field-error" id="decl_error" style="display:none;margin-top:6px">You must accept the declaration to submit.</span>
            </div>
        </div>
    </div>

    @* ── Form Actions ─────────────────────────────────────── *@
    <div class="form-actions">
        <a href="/Student/Dashboard" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            Submit Enrollment
        </button>
    </div>

</form>

@section Scripts {
<style>
/* Step bar */
.step-bar{display:flex;align-items:center;margin-bottom:24px;gap:0}
.step-item{display:flex;flex-direction:column;align-items:center;gap:5px;flex:0 0 auto}
.step-circle{width:30px;height:30px;border-radius:50%;background:var(--border-color);color:var(--text-muted);font-size:13px;font-weight:600;display:flex;align-items:center;justify-content:center;transition:.2s}
.step-item.active .step-circle{background:var(--color-primary);color:#fff}
.step-item.done .step-circle{background:var(--color-success);color:#fff}
.step-item span{font-size:11px;color:var(--text-muted);white-space:nowrap}
.step-item.active span{color:var(--color-primary);font-weight:600}
.step-item.done span{color:var(--color-success)}
.step-line{flex:1;height:2px;background:var(--border-color);margin:0 6px;margin-bottom:16px;transition:.2s}
.step-line.done{background:var(--color-success)}

/* Section numbering */
.sec-num{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:var(--color-primary);color:#fff;font-size:11px;font-weight:700;margin-right:6px;flex-shrink:0;vertical-align:middle}

/* Grids */
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:0 20px}
.form-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0 20px}

/* Fee context box */
.fee-context-box{display:flex;gap:10px;align-items:flex-start;background:#FFFBEB;border:1px solid #FCD34D;border-radius:var(--radius-md);padding:13px 15px;margin-bottom:18px;font-size:13px;color:#92400E;line-height:1.6}

/* Required star */
.req{color:var(--color-danger);margin-left:2px}

/* Review section */
.review-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.review-block{background:#F9FAFB;border:1px solid var(--border-color);border-radius:var(--radius-md);padding:16px}
.review-block-title{font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px}
.review-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border-color);font-size:13px;gap:12px}
.review-row:last-child{border-bottom:none;padding-bottom:0}
.review-row span{color:var(--text-secondary)}
.review-row strong{color:var(--text-primary);text-align:right;max-width:200px;word-break:break-word}

/* Declaration */
.declaration-box{background:#F0F9FF;border:1px solid #BAE6FD;border-radius:var(--radius-md);padding:16px 18px}

@@media(max-width:768px){
  .form-grid-2,.form-grid-3,.review-grid{grid-template-columns:1fr}
  .step-item span{display:none}
  .step-line{margin:0 4px;margin-bottom:14px}
}
</style>
<script>
// Sync semester display
document.getElementById('Semester')?.addEventListener('change', function() {
  document.getElementById('semDisplay').textContent = this.value || '—';
});

// Live review sync
function syncReview() {
  const get = id => document.getElementById(id)?.value || '';
  document.getElementById('rv_name').textContent    = get('FullName')    || '—';
  document.getElementById('rv_father').textContent  = get('FatherName')  || '—';
  document.getElementById('rv_prog').textContent    = get('DegreeProgram')|| '—';
  document.getElementById('rv_sec').textContent     = get('Section')     || '—';
  document.getElementById('rv_sem').textContent     = get('Semester')    || '—';
  document.getElementById('rv_phone').textContent   = get('PhoneNumber') || '—';
  document.getElementById('rv_courses').textContent = document.getElementById('totalCourses')?.textContent || '—';
  document.getElementById('rv_credits').textContent = document.getElementById('totalCredits')?.textContent || '—';
  const txn = get('TransactionId');
  document.getElementById('rv_txn').textContent = txn || 'Not provided';
}

['FullName','FatherName','DegreeProgram','Section','Semester','PhoneNumber','TransactionId']
  .forEach(id => document.getElementById(id)?.addEventListener('input', syncReview));

// Update review when courses change
const observer = new MutationObserver(syncReview);
const tc = document.getElementById('totalCourses');
if (tc) observer.observe(tc, { childList: true, characterData: true, subtree: true });

// Fee slip review update
document.getElementById('FeeSlipFile')?.addEventListener('change', function() {
  const el = document.getElementById('rv_feeslip');
  if (this.files[0]) {
    el.textContent = this.files[0].name;
    el.style.color = 'var(--color-success)';
  }
});

// Step bar — highlight based on scroll/focus
function updateSteps() {
  const sections = ['sec1','sec2','sec3','sec4'];
  const stepItems = ['si1','si2','si3','si4'];
  const stepLines = document.querySelectorAll('.step-line');

  sections.forEach((id, i) => {
    const sec = document.getElementById(id);
    const si  = document.getElementById(stepItems[i]);
    if (!sec || !si) return;
    const rect = sec.getBoundingClientRect();
    if (rect.top < window.innerHeight * 0.6 && rect.bottom > 0) {
      si.classList.add('active');
    }
    if (rect.bottom < 0) {
      si.classList.remove('active');
      si.classList.add('done');
      if (i < stepLines.length) stepLines[i].classList.add('done');
    }
  });
}
window.addEventListener('scroll', updateSteps, { passive: true });
updateSteps();

// Submit validation
document.getElementById('enrollForm').addEventListener('submit', function(e) {
  const decl = document.getElementById('declaration');
  const declErr = document.getElementById('decl_error');
  if (!decl.checked) {
    e.preventDefault();
    e.stopImmediatePropagation();
    declErr.style.display = 'block';
    decl.closest('.declaration-box').scrollIntoView({ behavior:'smooth', block:'center' });
    return;
  }
  declErr.style.display = 'none';

  const fi = document.getElementById('FeeSlipFile');
  if (!fi.files.length) {
    e.preventDefault();
    e.stopImmediatePropagation();
    document.getElementById('feeSlipDrop').style.borderColor = 'var(--color-danger)';
    document.getElementById('sec3').scrollIntoView({ behavior:'smooth', block:'start' });
    if (window.Toast) Toast.error('Please attach your fee slip before submitting.');
    return;
  }
  // Update button
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span> Submitting…';
});

// Initial sync
syncReview();
</script>
}
